NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tripcraft?retryWrites=true&w=majority

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_64_char_hex_secret_here
JWT_REFRESH_SECRET=your_64_char_hex_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini — free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash — free at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# CORS — React dev server origin
CLIENT_ORIGIN=http://localhost:5173

# Cookie signing secret
COOKIE_SECRET=your_32_char_hex_secret_here
